# 仓库默认环境变量（由 src/config.py 最先加载）；本地覆盖请复制为 .env：
# cp .env.example .env

# --- 数据与存储 ---
TODO_DATA_DIR=./data

# --- API 服务（监听地址与端口仅在此与 .env 中维护，代码中不硬编码）---
TODO_HOST=0.0.0.0
TODO_PORT=48890

# --- Webhook（待办服务主动 POST 的目标，需与 Link 等中间件监听地址一致）---
TODO_WEBHOOK_URL=http://localhost:49271/notify

# --- 定时推送时刻（本地时区）---
TODO_MORNING_HOUR=8
TODO_MORNING_MINUTE=0
TODO_EVENING_HOUR=21
TODO_EVENING_MINUTE=0
